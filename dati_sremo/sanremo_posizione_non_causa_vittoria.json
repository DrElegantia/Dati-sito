{
  "metadata": {
    "titolo": "Analisi statistica: la posizione centrale nell'ordine di esibizione a Sanremo NON causa un vantaggio",
    "tesi_da_confutare": "Esibirsi al centro dell'ordine di esibizione conferisce un vantaggio competitivo a Sanremo",
    "conclusione": "La correlazione osservata tra posizione centrale e classifica migliore è spuria: è il direttore artistico che colloca i favoriti al centro, non la posizione centrale che fa vincere",
    "fonte_dati": "sanremo_dati_serate.xlsx",
    "anni_analizzati": [
      2018,
      2019,
      2020,
      2021,
      2022,
      2023,
      2024,
      2025,
      2026
    ],
    "totale_osservazioni": 939,
    "totale_osservazioni_con_televoto": 647,
    "totale_serate_analizzate": 45,
    "nota_metodologica": "Le posizioni e le classifiche sono normalizzate in scala [0,1] per rendere confrontabili serate con numeri diversi di esibizioni. pos_norm=0 è il primo, pos_norm=1 è l'ultimo. rank_norm=0 è il primo in classifica, rank_norm=1 è l'ultimo."
  },
  "sezione_1_correlazione_debole": {
    "titolo": "La correlazione esiste ma è molto debole",
    "spiegazione": "Anche se la correlazione è statisticamente significativa (p < 0.05), l'effetto è molto piccolo. La posizione spiega solo il 6.24% della varianza nella classifica. Il 93.76% dipende da altri fattori.",
    "correlazione_spearman": {
      "distanza_dal_centro_vs_classifica": {
        "rho": 0.2727,
        "p_value": 1.8e-17,
        "interpretazione": "Correlazione debole positiva: chi è più lontano dal centro tende leggermente a classificarsi peggio, ma rho=0.2727 è un effetto molto piccolo"
      },
      "posizione_lineare_vs_classifica": {
        "rho": 0.1245,
        "p_value": 0.000131,
        "interpretazione": "La posizione lineare (prima→ultima) ha una correlazione ancora più debole con la classifica"
      }
    },
    "regressione_lineare": {
      "distanza_dal_centro": {
        "R_quadro": 0.0624,
        "percentuale_varianza_spiegata": 6.24,
        "percentuale_varianza_NON_spiegata": 93.76,
        "interpretazione": "La distanza dal centro spiega solo il 6.24% della varianza. Il 93.76% dipende da altri fattori (qualità artista, canzone, esecuzione, ecc.)"
      },
      "posizione_lineare": {
        "R_quadro": 0.0124,
        "percentuale_varianza_spiegata": 1.24
      }
    },
    "effect_size_cohen_d": {
      "valore": 0.4009,
      "interpretazione": "Cohen's d = 0.40 è un effetto piccolo-medio secondo le convenzioni di Cohen (0.2=piccolo, 0.5=medio, 0.8=grande). Esiste una differenza tra centro e non-centro, ma come dimostrato nelle sezioni successive, questa differenza è interamente spiegata dal confondente (il direttore artistico posiziona i favoriti al centro)."
    }
  },
  "sezione_2_esperimento_naturale_stesso_artista": {
    "titolo": "L'ESPERIMENTO NATURALE: stesso artista, posizioni diverse → classifica stabile",
    "spiegazione": "Questa è la prova più forte contro la causalità. Lo stesso artista si esibisce in posizioni DIVERSE nelle varie serate dello stesso anno. Se la posizione causasse il risultato, ci aspetteremmo che cambiando posizione, la classifica cambi di conseguenza. Invece la classifica rimane sostanzialmente stabile: è la QUALITÀ dell'artista/canzone a determinare il risultato, non la posizione.",
    "analisi_correlazione_intra_artista": {
      "spiegazione": "Per ogni artista con almeno 4 serate nello stesso anno, calcoliamo la correlazione tra posizione e classifica",
      "totale_artisti_analizzati": 223,
      "correlazione_media": 0.1033,
      "correlazione_mediana": 0.2,
      "artisti_con_correlazione_significativa": 13,
      "percentuale_significativi": 5.8,
      "tasso_falsi_positivi_atteso": 5.0,
      "interpretazione": "Solo il 5.8% degli artisti mostra una correlazione significativa tra posizione e classifica. Questo è appena sopra il 5% atteso per puro caso (falsi positivi). La correlazione media è r=0.1033, praticamente zero. Questo dimostra che quando controlliamo per la qualità dell'artista (confrontando lo STESSO artista), l'effetto della posizione SCOMPARE."
    },
    "variazione_intra_artista": {
      "deviazione_std_media_posizione": 0.3023,
      "deviazione_std_media_classifica": 0.1679,
      "interpretazione": "La posizione varia molto tra serate (std~0.30) ma la classifica è molto più stabile (std~0.17). La classifica è determinata dalla qualità, non dalla posizione."
    },
